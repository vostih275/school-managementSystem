# =============================================================================
# Production environment variables example
# ---------------------------------------------------------------------------
# Copy this file to .env and fill in real values before running locally.
# In production (e.g. Render), set these values in the platform dashboard.
# NEVER commit real secrets to version control.
# =============================================================================

# Node environment
NODE_ENV=production

# Port the server listens on. Render sets this automatically.
PORT=5000

# MongoDB connection string
MONGODB_URI=

# Secret used to sign JWT auth tokens. Generate a strong random string.
JWT_SECRET=

# Optional: school name used in temp password generation and reports
SCHOOL_NAME=AIC
